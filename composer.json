{
  "name": "your-vendor-name/moneyfusion-laravel",
  "description": "A Laravel package for easy integration with MoneyFusion payment gateway.",
  "keywords": ["laravel", "moneyfusion", "payment", "gateway", "billing", "invoice"],
  "license": "MIT",
  "authors": [
    {
      "name": "Your Name",
      "email": "your.email@example.com"
    }
  ],
  "require": {
    "php": "^8.2",
    "illuminate/support": "^10.0 || ^11.0",
    "illuminate/database": "^10.0 || ^11.0",
    "illuminate/http": "^10.0 || ^11.0",
    "illuminate/console": "^10.0 || ^11.0",
    "illuminate/mail": "^10.0 || ^11.0",
    "barryvdh/laravel-dompdf": "^2.1"
  },
  "autoload": {
    "psr-4": {
      "Vendor\\MoneyFusion\\": "src/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Vendor\\MoneyFusion\\MoneyFusionServiceProvider"
      ],
      "aliases": {
        "MoneyFusion": "Vendor\\MoneyFusion\\Facades\\MoneyFusion"
      }
    }
  },
  "minimum-stability": "dev",
  "prefer-stable": true
}